# Firebase - app "escuelariver" (proyecto lexflow-consultas)
# Obtener desde: Firebase Console → lexflow-consultas → Configuración (engranaje) → Tus apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=lexflow-consultas.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=lexflow-consultas
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=lexflow-consultas.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=664196918383
NEXT_PUBLIC_FIREBASE_APP_ID=1:664196918383:web:e58546257d0d98e9fdf19a

# Genkit / Google AI (Gemini)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# URL base de la app (localhost en desarrollo, URL real en producción)
NEXT_PUBLIC_APP_URL=http://localhost:9003

# Mercado Pago OAuth
# MERCADOPAGO_CLIENT_ID=
# MERCADOPAGO_CLIENT_SECRET=

# WhatsApp (opcional)
# PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_TOKEN=

# NotificasHub (opcional)
# NOTIFICASHUB_PROJECT_ID=
# NOTIFICASHUB_CLIENT_EMAIL=
# NOTIFICASHUB_PRIVATE_KEY=

# Cuenta de servicio (para firebase-admin: scripts, API routes)
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
